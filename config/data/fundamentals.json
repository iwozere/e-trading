  "provider_settings": {
    "fmp": {
      "name": "Financial Modeling Prep",
      "priority": 1,
      "rate_limits": {
        "requests_per_minute": 3000,
        "requests_per_day": null
      },
      "data_quality": 5,
      "reliability": 5,
      "coverage": "excellent",
      "api_key_required": true,
      "api_key_env": "FMP_API_KEY",
      "strengths": [
        "structured_statements",
        "comprehensive_ratios",
        "historical_data"
      ],
      "limitations": [
        "daily_cap",
        "some_fields_paywalled"
      ]
    },
    "yahoo": {
